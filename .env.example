# Server Configuration
SERVER_HOST=your_server_ip
SERVER_PORT=22
SERVER_USER=root
# Use either PASSWORD or PRIVATE_KEY_PATH
SERVER_PASSWORD=your_password
# SERVER_PRIVATE_KEY_PATH=C:/Users/YourUser/.ssh/id_rsa

# Deployment Configuration
# The directory on the server where the site should be deployed
REMOTE_DEST_PATH=/www/wwwroot/public
# Number of backups to keep (optional, default: 5)
KEEP_RELEASES=5

# AI Assistant API Keys
# 硅基流动API密钥（多个密钥用于轮询）
SILICON_FLOW_API_KEY_1=your_silicon_flow_api_key_1
SILICON_FLOW_API_KEY_2=your_silicon_flow_api_key_2
# DeepSeek API密钥（备用）
DEEPSEEK_API_KEY=your_deepseek_api_key
